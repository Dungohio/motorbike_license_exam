{
  "info": {
    "name": "Motorbike License Exam API",
    "description": "Bộ API test cho web ôn thi bằng lái xe máy (Express + Mongoose). Đăng nhập trước để tự lưu token vào biến {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyen Van A\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "if (data.token) { pm.environment.set('token', data.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Login (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "if (data.token) { pm.environment.set('token', data.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"user123\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Users (Profile)",
      "item": [
        {
          "name": "Update profile (name, avatar)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Tên mới\",\n  \"avatar\": \"avatar3\"\n}" }
          }
        },
        {
          "name": "Upload avatar (form-data)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/me/avatar", "host": ["{{baseUrl}}"], "path": ["users", "me", "avatar"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "avatar", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Change password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/users/me/password", "host": ["{{baseUrl}}"], "path": ["users", "me", "password"] },
            "body": { "mode": "raw", "raw": "{\n  \"oldPassword\": \"user123\",\n  \"newPassword\": \"newpass123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "License Classes",
      "item": [
        {
          "name": "Get license classes",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/license-classes", "host": ["{{baseUrl}}"], "path": ["license-classes"] }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Create category (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Kỹ thuật lái xe\",\n  \"description\": \"Câu hỏi về kỹ thuật lái xe an toàn\"\n}" }
          }
        },
        {
          "name": "Update category (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/categories/:id", "host": ["{{baseUrl}}"], "path": ["categories", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Tên chủ đề mới\"\n}" }
          }
        },
        {
          "name": "Delete category (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/categories/:id", "host": ["{{baseUrl}}"], "path": ["categories", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },
    {
      "name": "Questions (Admin)",
      "item": [
        {
          "name": "List questions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/questions?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["questions"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "licenseClass", "value": "", "disabled": true },
                { "key": "category", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get question by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/questions/:id", "host": ["{{baseUrl}}"], "path": ["questions", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Create question",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/questions", "host": ["{{baseUrl}}"], "path": ["questions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"licenseClass\": \"<licenseClassId>\",\n  \"category\": \"<categoryId>\",\n  \"content\": \"Câu hỏi mẫu?\",\n  \"imageUrl\": \"\",\n  \"options\": [\"Đáp án A\", \"Đáp án B\", \"Đáp án C\"],\n  \"correctIndex\": 0,\n  \"explanation\": \"Giải thích...\",\n  \"isCritical\": false\n}"
            }
          }
        },
        {
          "name": "Update question",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/questions/:id", "host": ["{{baseUrl}}"], "path": ["questions", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Nội dung câu hỏi đã sửa\"\n}" }
          }
        },
        {
          "name": "Delete question",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/questions/:id", "host": ["{{baseUrl}}"], "path": ["questions", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },
    {
      "name": "Practice & Exam (User)",
      "item": [
        {
          "name": "Practice questions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/practice?licenseClass=<licenseClassId>",
              "host": ["{{baseUrl}}"],
              "path": ["practice"],
              "query": [
                { "key": "licenseClass", "value": "<licenseClassId>" },
                { "key": "category", "value": "", "disabled": true },
                { "key": "critical", "value": "true", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Generate exam",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/exams/generate", "host": ["{{baseUrl}}"], "path": ["exams", "generate"] },
            "body": { "mode": "raw", "raw": "{\n  \"licenseClass\": \"<licenseClassId>\"\n}" }
          }
        },
        {
          "name": "Submit exam",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/exams/submit", "host": ["{{baseUrl}}"], "path": ["exams", "submit"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"licenseClass\": \"<licenseClassId>\",\n  \"startedAt\": \"2026-07-09T00:00:00.000Z\",\n  \"durationSeconds\": 300,\n  \"answers\": [\n    { \"question\": \"<questionId>\", \"selectedIndex\": 0 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Exam stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/exams/stats", "host": ["{{baseUrl}}"], "path": ["exams", "stats"] }
          }
        },
        {
          "name": "Exam history",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/exams/history", "host": ["{{baseUrl}}"], "path": ["exams", "history"] }
          }
        },
        {
          "name": "Exam history detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/exams/history/:id", "host": ["{{baseUrl}}"], "path": ["exams", "history", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    }
  ]
}
